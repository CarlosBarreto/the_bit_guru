# bit_guru — secrets locales (NO commitear)
#
# Flujo (por sesión, no persistente):
#   1. Copy-Item .env.example .env
#   2. Rellena los valores reales abajo.
#   3. En PowerShell, parado en la raíz del proyecto:
#        .\Load-Env.ps1
#        code .
#      VS Code y Claude Code heredan el environment de esa terminal.
#
# El .env real está en .gitignore — no se sube al repo.

# --- Stitch MCP (diseño UI) ---
# Obtener en: https://stitch.withgoogle.com (sección API)
STITCH_API_KEY=

# --- Gemini (futuro, cuando los endpoints Astro entren) ---
# La clave previa quedó bloqueada en Google Cloud el 2026-05-28. Rotar y pegar.
# GEMINI_API_KEY=
