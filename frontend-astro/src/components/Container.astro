---
// src/components/Container.astro — feature 15 (redesign_layout_primitives).
// Primitivo de layout editorial (spec § LAYOUT): rejilla de 12 columnas,
// max-width 1200px centrado en el viewport, gutter --space-5 (24px) y márgenes
// laterales de la escala --space-*. El contenido se alinea a la IZQUIERDA; el
// centrado es solo del bloque respecto al viewport, no del texto interior.
// Consume SOLO tokens de Layout.astro (--space-*); cero hex sueltos, sin glow.
//
// Uso: <Container> ... </Container>. Por defecto renderiza un <div>; se puede
// cambiar la etiqueta semántica con la prop `as` (p. ej. as="section").
export interface Props {
  as?: string;
  class?: string;
}

const { as = "div", class: className } = Astro.props;
const Tag = as;
---

<Tag class:list={["container", className]}>
  <slot />
</Tag>

<style>
  .container {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: var(--space-5);
    row-gap: var(--space-5);
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-7);
    text-align: left;
  }

  /* Tablet: márgenes laterales algo más ajustados (spec § LAYOUT breakpoints). */
  @media (max-width: 1023px) {
    .container {
      padding-inline: var(--space-6);
    }
  }

  /* Móvil: 1 columna, prosa full-width con márgenes --space-5 (spec § LAYOUT). */
  @media (max-width: 640px) {
    .container {
      grid-template-columns: 1fr;
      padding-inline: var(--space-5);
    }
  }
</style>
