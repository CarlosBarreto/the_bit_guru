---
// src/components/WhitePaperLayout.astro — feature 21 (redesign_page_metodologia).
// Layout de documento largo (docs/design/redesign_advisory_spec.md
// § REQUIRED COMPONENTS "/metodologia · WhitePaperLayout"): portada, índice y
// secciones numeradas con nota al margen opcional. Registro: white paper
// institucional impreso (papel cálido, hairlines, mono para metadatos).
//
// El cuerpo de cada sección llega como SLOT NOMBRADO cuyo nombre es el `id` de
// la sección: la página declara <Fragment slot="resumen-ejecutivo">…</Fragment>
// y este layout lo resuelve con `await Astro.slots.render(section.id)` (API
// estable de Astro, compatible con la Container API de los tests).
//
// Reusable: NO fija familia de acento. Consume SOLO tokens de Layout.astro
// (--ink*, --accent*, --paper*, --space-*, --step-*, --font-*, --radius,
// --measure). Cero hex de marca, sin gradiente, sin glow/box-shadow, sin dark
// mode, sin emoji. Todo alineado a la izquierda.
export interface WhitePaperSection {
  id: string;
  title: string;
  note?: string;
}

export interface Props {
  code: string;
  title: string;
  deck?: string;
  meta?: { label: string; value: string }[];
  sections: WhitePaperSection[];
}

const { code, title, deck, meta = [], sections } = Astro.props;

// Resuelve el slot nombrado de cada sección ANTES del template (slots.render
// es asíncrono). Una sección sin slot renderiza vacía sin romper.
const renderedSections = await Promise.all(
  sections.map(async (section, index) => ({
    ...section,
    number: index + 1,
    body: Astro.slots.has(section.id)
      ? await Astro.slots.render(section.id)
      : "",
  })),
);
---

<article class="white-paper">
  {/* PORTADA: código de documento (mono), H1 serif, deck y metadatos. */}
  <header class="cover">
    <p class="doc-code">{code}</p>
    <h1 class="doc-title">{title}</h1>
    {deck && <p class="doc-deck">{deck}</p>}
    {
      meta.length > 0 && (
        <dl class="meta">
          {meta.map((entry) => (
            <div class="meta-row">
              <dt>{entry.label}</dt>
              <dd>{entry.value}</dd>
            </div>
          ))}
        </dl>
      )
    }
  </header>

  {/* ÍNDICE: enlaces ancla a cada sección numerada. */}
  <nav class="toc" aria-label="Índice">
    <h2 class="toc-title">Índice</h2>
    <ol class="toc-list">
      {
        renderedSections.map((section) => (
          <li class="toc-entry">
            <a href={`#${section.id}`}>
              <span class="toc-number">{section.number}.</span>
              <span class="toc-label">{section.title}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </nav>

  {/* SECCIONES NUMERADAS: h2 = número (mono, acento) + título serif; nota al
      margen opcional; cuerpo inyectado desde el slot nombrado de la página. */}
  {
    renderedSections.map((section) => (
      <section
        class="wp-section"
        id={section.id}
        aria-labelledby={`${section.id}-title`}
      >
        <div class="wp-section-main">
          <h2 class="wp-section-title" id={`${section.id}-title`}>
            <span class="section-number">{section.number}.</span>
            {section.title}
          </h2>
          <div class="wp-section-body" set:html={section.body} />
        </div>
        {section.note && <aside class="margin-note">{section.note}</aside>}
      </section>
    ))
  }
</article>

<style>
  .white-paper {
    text-align: left;
  }

  /* ---- Portada ---- */
  .cover {
    border-top: 3px solid var(--ink-deep);
    border-bottom: 1px solid var(--ink-rule);
    padding-block: var(--space-6) var(--space-7);
    margin-bottom: var(--space-7);
  }

  .doc-code {
    margin: 0 0 var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .doc-title {
    margin: 0;
    max-width: var(--measure);
    font-family: var(--font-serif);
    font-size: var(--step-4);
    font-weight: 600;
    line-height: 1.15;
    color: var(--ink-deep);
  }

  .doc-deck {
    margin: var(--space-5) 0 0;
    max-width: var(--measure);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--ink-muted);
  }

  .meta {
    margin: var(--space-6) 0 0;
    max-width: var(--measure);
    border-top: 1px solid var(--ink-rule);
  }

  .meta-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    column-gap: var(--space-5);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--ink-rule);
  }

  .meta dt {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .meta dd {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--step-0);
    color: var(--ink);
  }

  /* ---- Índice ---- */
  .toc {
    max-width: var(--measure);
    margin-bottom: var(--space-8);
  }

  .toc-title {
    margin: 0 0 var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc-entry {
    border-top: 1px solid var(--ink-rule);
  }

  .toc-entry:last-child {
    border-bottom: 1px solid var(--ink-rule);
  }

  .toc-entry a {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
    padding-block: var(--space-3);
    text-decoration: none;
  }

  .toc-number {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--accent);
  }

  .toc-label {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--ink);
  }

  .toc-entry a:hover .toc-label,
  .toc-entry a:focus-visible .toc-label {
    color: var(--accent);
  }

  .toc-entry a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ---- Secciones numeradas ---- */
  .wp-section {
    display: grid;
    grid-template-columns: minmax(0, var(--measure)) minmax(0, 1fr);
    column-gap: var(--space-7);
    align-items: start;
    border-top: 1px solid var(--ink-rule);
    padding-top: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .wp-section-main {
    max-width: var(--measure);
  }

  .wp-section-title {
    margin: 0 0 var(--space-5);
    font-family: var(--font-serif);
    font-size: var(--step-2);
    font-weight: 600;
    line-height: 1.2;
    color: var(--ink-deep);
  }

  .section-number {
    margin-right: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--step-1);
    font-weight: 500;
    color: var(--accent);
  }

  /* Nota al margen: ficha seca en mono/sans pequeño con filete de acento. */
  .margin-note {
    border-left: 2px solid var(--accent);
    border-radius: var(--radius);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    line-height: 1.5;
    color: var(--ink-muted);
  }

  @media (max-width: 1023px) {
    .wp-section {
      grid-template-columns: 1fr;
      row-gap: var(--space-5);
    }

    .margin-note {
      max-width: var(--measure);
    }
  }
</style>
