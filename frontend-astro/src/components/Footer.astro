---
// src/components/Footer.astro — feature 16 (redesign_nav_footer).
// Pie de página del rediseño (docs/design/redesign_advisory_spec.md
// § REQUIRED COMPONENTS / VOICE & COPY): directorio de secciones (mismas 6
// rutas que TopNavigation), disclaimer cínico-institucional y firma del Socio
// Fundador. SIN año ni "© sin fecha" (el Gurú opera fuera del tiempo). Registro
// consultora deadpan (usted), voz canónica preservada. Consume SOLO tokens de
// Layout.astro (--accent*, --ink*, --paper*, --space-*, --step-*, --font-*);
// sin degradados, sin sombra luminosa, sin dark mode, sin hex sueltos.
import { NAV_LINKS, HOME_HREF } from "./nav-links";
---

<footer id="footer" aria-label="Pie de página">
  <div class="footer-inner">
    <div class="brand">
      <a class="wordmark" href={HOME_HREF}>
        Bit Gurú <span class="wordmark-sub">· Asesoría Estratégica</span>
      </a>
      <p class="disclaimer">
        Resultados obtenidos en líneas temporales anteriores no garantizan
        rendimientos futuros. Si llegó hasta aquí, ya sabe con quién trata.
      </p>
    </div>

    <nav class="directory" aria-label="Directorio de secciones">
      <p class="directory-title">Secciones</p>
      <ul>
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <p class="signature">
    El Gurú de Bits — Socio Fundador.
    Operando desde los espacios muertos entre paquetes.
  </p>
</footer>

<style>
  #footer {
    background: var(--paper-deep);
    border-top: 1px solid var(--ink-rule);
    padding: var(--space-9) var(--space-7) var(--space-7);
    text-align: left;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
  }

  .brand {
    max-width: var(--measure);
  }

  .wordmark {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--step-2);
    color: var(--ink-deep);
    text-decoration: none;
  }

  .wordmark-sub {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    color: var(--ink-muted);
  }

  .disclaimer {
    font-family: var(--font-serif);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--ink-muted);
    max-width: 52ch;
    margin: var(--space-4) 0 0;
  }

  .directory-title {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin: 0 0 var(--space-3);
  }

  .directory ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  .directory a {
    font-family: var(--font-sans);
    font-size: var(--step-0);
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--ink-rule);
    text-underline-offset: 0.2em;
    transition: color 150ms ease-out, text-decoration-color 150ms ease-out;
  }

  .directory a:hover,
  .directory a:focus-visible {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .directory a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .signature {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--ink-muted);
    max-width: 1200px;
    margin: var(--space-8) auto 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--ink-rule);
  }

  @media (max-width: 1023px) {
    #footer {
      padding: var(--space-8) var(--space-6) var(--space-7);
    }
  }

  @media (max-width: 640px) {
    #footer {
      padding: var(--space-8) var(--space-5) var(--space-6);
    }

    .footer-inner {
      flex-direction: column;
      gap: var(--space-6);
    }
  }
</style>
