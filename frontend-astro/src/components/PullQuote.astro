---
// src/components/PullQuote.astro — feature 17 (redesign_editorial_components_a).
// Cita editorial del rediseño (docs/design/redesign_advisory_spec.md
// § REQUIRED COMPONENTS / TYPOGRAPHY): cita serif grande (--step-2 → --step-3)
// con filete de acento a la IZQUIERDA (border-left 3px solid var(--accent) +
// padding-left). Sobrio: sin comillas decorativas gigantes. Semántica real con
// <blockquote> y <cite>. Registro consultora (usted, deadpan).
// Consume SOLO tokens de Layout.astro (--accent*, --ink*, --paper*, --space-*,
// --step-*, --font-*, --measure). Cero hex de marca, sin gradiente, sin glow,
// sin dark mode, sin emoji.
//
// Reusable: NO fija familia de acento. Usa --accent, que la página remapea con
// <body data-accent="...">. La atribución <cite> se omite del DOM sin `cite`.
export interface Props {
  quote: string;
  cite?: string;
}

const { quote, cite } = Astro.props;
---

<blockquote class="pull-quote">
  <p class="quote">{quote}</p>
  {cite && <cite class="cite">{cite}</cite>}
</blockquote>

<style>
  /* Filete de acento a la izquierda (border-left 3px solid var(--accent)) +
     padding-left. Texto alineado a la izquierda, medida de lectura. */
  .pull-quote {
    margin: var(--space-7) 0;
    max-width: var(--measure);
    border-left: 3px solid var(--accent);
    padding-left: var(--space-5);
    text-align: left;
  }

  /* Cita serif grande, --step-2 → --step-3 (spec § TYPOGRAPHY escala). */
  .quote {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(var(--step-2), 3vw, var(--step-3));
    line-height: 1.4;
    color: var(--ink-deep);
  }

  /* Atribución sobria: sans, --step--1, color --ink-muted. */
  .cite {
    display: block;
    margin-top: var(--space-4);
    font-family: var(--font-sans);
    font-style: normal;
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--ink-muted);
  }
</style>
