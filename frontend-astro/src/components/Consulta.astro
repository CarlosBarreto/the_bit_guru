---
// src/components/Consulta.astro — feature 13 (ui_port_astro).
// Sección de consulta directa al Gurú: textarea + botón "INVOCAR". Al invocar
// hace POST /api/pregunta con { pregunta } y pinta la `respuesta`. Maneja
// textarea vacío (no dispara, microcopy) y fallo de fetch con filo cínico
// (brief §2). Fondo --surface-card; botón --morado (marca). NUNCA --rosa.
// <style> scoped.
---

<section id="consulta">
  <div class="consulta-wrap">
    <header class="consulta-head">
      <p class="consulta-kicker">Pregúntale al Gurú</p>
      <h2 class="consulta-title">Suéltalo. Aquí entre nos.</h2>
      <p class="consulta-sub">
        Escribe lo que te quita el sueño. El Gurú no juzga… mucho.
      </p>
    </header>

    <div class="consulta-form">
      <textarea
        data-pregunta
        class="consulta-textarea"
        rows="4"
        placeholder="¿Qué te atormenta, mortal?"
        aria-label="Tu pregunta para el Gurú"></textarea>

      <button type="button" class="invocar-btn" data-invocar>
        INVOCAR
      </button>
    </div>

    <p class="consulta-msg" data-msg hidden role="status"></p>

    <blockquote class="consulta-respuesta" data-respuesta hidden></blockquote>
  </div>
</section>

<style>
  #consulta {
    background: var(--surface-card);
    padding: 6rem 1.5rem;
  }

  .consulta-wrap {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .consulta-head {
    text-align: center;
  }

  .consulta-kicker {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
    color: var(--cyan);
    margin: 0 0 0.75rem;
  }

  .consulta-title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: var(--texto-fuerte);
    margin: 0 0 0.5rem;
  }

  .consulta-sub {
    font-family: var(--font-body);
    color: var(--texto);
    opacity: 0.8;
    margin: 0;
  }

  .consulta-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .consulta-textarea {
    width: 100%;
    resize: vertical;
    min-height: 120px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--texto-fuerte);
    background: var(--surface-hex);
    border: 1px solid color-mix(in srgb, var(--morado) 35%, transparent);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .consulta-textarea::placeholder {
    color: color-mix(in srgb, var(--texto) 55%, transparent);
  }

  .consulta-textarea:focus {
    outline: none;
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--cyan) 25%, transparent);
  }

  /* Botón de marca: --morado, NUNCA --rosa (ese es solo para la tirada). */
  .invocar-btn {
    align-self: center;
    font-family: var(--font-head);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 1rem;
    color: var(--texto-fuerte);
    background: var(--morado);
    border: none;
    border-radius: 999px;
    padding: 0.9rem 2.5rem;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .invocar-btn:hover {
    transform: translateY(-3px);
    background: color-mix(in srgb, var(--morado) 80%, var(--morado-claro));
    box-shadow: 0 0 28px color-mix(in srgb, var(--morado) 55%, transparent);
  }

  .invocar-btn:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .consulta-msg {
    font-family: var(--font-mono);
    color: var(--cyan);
    text-align: center;
    margin: 0;
  }

  .consulta-msg[hidden],
  .consulta-respuesta[hidden] {
    display: none;
  }

  .consulta-respuesta {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--texto-fuerte);
    background: var(--surface-section);
    border-left: 3px solid var(--cyan);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    margin: 0;
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>(
    "#consulta [data-invocar]",
  );
  const textarea = document.querySelector<HTMLTextAreaElement>(
    "#consulta [data-pregunta]",
  );
  const msgEl = document.querySelector<HTMLElement>("#consulta [data-msg]");
  const respuestaEl = document.querySelector<HTMLElement>(
    "#consulta [data-respuesta]",
  );

  function mostrarMsg(texto: string) {
    if (!msgEl) return;
    msgEl.textContent = texto;
    msgEl.hidden = false;
  }

  function limpiarMsg() {
    if (!msgEl) return;
    msgEl.textContent = "";
    msgEl.hidden = true;
  }

  function mostrarRespuesta(texto: string) {
    if (!respuestaEl) return;
    respuestaEl.textContent = texto;
    respuestaEl.hidden = false;
  }

  btn?.addEventListener("click", async () => {
    const pregunta = textarea?.value.trim() ?? "";

    if (!pregunta) {
      mostrarMsg("Primero escribe algo, mortal. El vacío no se consulta.");
      return;
    }

    limpiarMsg();
    btn.disabled = true;
    const textoOriginal = btn.textContent;
    btn.textContent = "INVOCANDO…";

    try {
      const res = await fetch("/api/pregunta", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ pregunta }),
      });
      if (!res.ok) throw new Error("respuesta no ok");
      const data = (await res.json()) as { respuesta?: string };
      if (!data.respuesta) throw new Error("respuesta vacía");
      mostrarRespuesta(data.respuesta);
    } catch {
      mostrarMsg("Los espíritus tienen lag. Inténtalo de nuevo, mortal.");
    } finally {
      btn.disabled = false;
      btn.textContent = textoOriginal;
    }
  });
</script>
