---
// src/components/InsightCard.astro — feature 18 (redesign_editorial_components_b).
// Tarjeta de memo / insight (docs/design/redesign_advisory_spec.md
// § REQUIRED COMPONENTS "InsightCard" / TYPOGRAPHY / LAYOUT): eyebrow mono
// opcional + título serif (--step-2) + extracto breve (--ink) + fecha en mono
// (--step--1, --ink-muted). Estructura con <article>. Borde hairline 1px
// var(--ink-rule) + filete superior de acento; SIN sombra/glow. Si hay `href`,
// el título es el enlace (con foco visible). Alineado a la IZQUIERDA.
// Registro consultora (usted, deadpan).
//
// Reusable: NO fija familia de acento. Usa --accent, que la página remapea con
// <body data-accent="...">. Consume SOLO tokens de Layout.astro (--accent*,
// --ink*, --paper*, --space-*, --step-*, --font-*, --radius). Cero hex de marca,
// sin gradiente, sin glow/box-shadow luminosa, sin dark mode, sin emoji.
export interface Props {
  eyebrow?: string;
  title: string;
  excerpt?: string;
  date?: string;
  href?: string;
}

const { eyebrow, title, excerpt, date, href } = Astro.props;
---

<article class="insight-card">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h3 class="title">
    {href ? <a class="title-link" href={href}>{title}</a> : title}
  </h3>
  {excerpt && <p class="excerpt">{excerpt}</p>}
  {date && <p class="date">{date}</p>}
</article>

<style>
  /* Tarjeta editorial: borde hairline 1px var(--ink-rule) + filete superior de
     acento (border-top 2px var(--accent)). Sin sombra/glow. Esquinas casi
     rectas (--radius). Alineada a la izquierda. */
  .insight-card {
    border: 1px solid var(--ink-rule);
    border-top: 2px solid var(--accent);
    border-radius: var(--radius);
    padding: var(--space-5);
    background: var(--paper-pure);
    text-align: left;
  }

  /* Eyebrow en mono, MAYÚSCULAS, letter-spacing 0.08em, color --accent
     (spec § TYPOGRAPHY "Eyebrows"). */
  .eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
  }

  /* Título en serif editorial, --step-2 (H3). line-height de headline 1.2. */
  .title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--step-2);
    line-height: 1.2;
    color: var(--ink-deep);
  }

  /* El enlace del título no depende solo del color: subrayado + color --accent.
     Foco visible (spec § ACCESSIBILITY). */
  .title-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 150ms ease-out;
  }

  .title-link:hover {
    color: var(--accent-bright);
  }

  .title-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Extracto breve: serif de cuerpo, color --ink, alineado a la izquierda. */
  .excerpt {
    margin: var(--space-4) 0 0;
    font-family: var(--font-serif);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--ink);
  }

  /* Fecha / metadato en mono, --step--1, color --ink-muted. */
  .date {
    margin: var(--space-4) 0 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--ink-muted);
  }
</style>
