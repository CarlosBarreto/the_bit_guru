---
import Layout from '../layouts/Layout.astro';
---



<Layout title="Quejas - Gurú de Bits">
	<main class="container">
		<h1>Queja Generada</h1>
		<div class="card" id="terminal">
			
		</div>
		<a href="/" class="cta-button">Volver</a>
	</main>
</Layout>

<style>
        body {
            background-color: #000;
            color: #0f0;
            font-family: 'Courier New', Courier, monospace;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            padding: 20px;
            box-sizing: border-box;
        }

        #terminal {
            white-space: pre-wrap;
            word-wrap: break-word;
            font-size: 1.5rem;
            text-shadow: 0 0 5px #0f0;
        }

        .cursor {
            font-size: 1.5rem;
            color: #0f0;
            animation: blink 1s step-end infinite;
        }

        @keyframes blink {
            from, to {
                color: transparent;
            }
            50% {
                color: #0f0;
            }
        }
    </style>

</head>



<script>
	import { getMorpheusQuotes } from '../utils/api.js';

	const terminal = document.getElementById('terminal');
	let morpheusQuotes: string[] = [];
	let quoteIndex = 0;
	let charIndex = 0;
	const typingSpeed = 50;
	const delayBetweenQuotes = 3000;

	async function loadQuotes() {
		try {
			morpheusQuotes = await getMorpheusQuotes();
		} catch (error) {
			console.error('Error al cargar las citas:', error);
			// Las citas por defecto ya están manejadas en getMorpheusQuotes
		}
	}

	function typeWriter() {
		if (!terminal) return;

		if (quoteIndex < morpheusQuotes.length) {
			const currentQuote = morpheusQuotes[quoteIndex];
			if (charIndex < currentQuote.length) {
				terminal.textContent += currentQuote.charAt(charIndex);
				charIndex++;
				setTimeout(typeWriter, typingSpeed);
			} else {
				terminal.textContent += '\n\n'; // Salto de línea doble al terminar la frase
				charIndex = 0;
				quoteIndex++;
				setTimeout(typeWriter, delayBetweenQuotes);
			}
		} else {
			// Reiniciar el ciclo de frases
			quoteIndex = 0;
			terminal.textContent = '';
			setTimeout(typeWriter, delayBetweenQuotes);
		}
	}

	// Iniciar el efecto de escritura
	window.onload = async function() {
		await loadQuotes();

		if (!terminal) return;

		// Agregar un cursor parpadeante
		const cursorSpan = document.createElement('span');
		cursorSpan.className = 'cursor';
		cursorSpan.innerHTML = '█';
		terminal.appendChild(cursorSpan);

		// Iniciar la escritura después de un pequeño retraso
		setTimeout(typeWriter, 1000);
	};
</script>
