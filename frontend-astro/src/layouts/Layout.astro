---
// src/layouts/Layout.astro
// Fundación de la UI (feature 13). Define los tokens canónicos del brief §1 /
// PERSONA §8, carga las 4 fuentes y el reset/base global. Los componentes del
// lote paralelo SOLO consumen estas custom properties; no redefinen la paleta.
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="El Oráculo del Gurú de Bits — tarot cibernético en la era de la información." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fuentes canónicas (brief §1). Google Fonts permitido; Tailwind por CDN NO. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,700;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ── Tokens canónicos (brief §1 + PERSONA §8). CONTRATO COMPARTIDO ──────────
     morado = marca/primario · cyan = interactivo/místico · rosa = SOLO CTA de
     tirada. Los componentes consumen estas variables; no introducen otros hex. */
  :root {
    --bg: #0a0a0f; /* negro profundo, fondo */
    --surface-footer: #050508;
    --surface-section: #15151e;
    --surface-card: #1f1f2e; /* card de consulta */
    --surface-hex: #2a2a40; /* cartas hex y botones secundarios */
    --morado: #7b2cbf; /* MARCA / primario */
    --morado-claro: #d4bbff; /* hover/highlight */
    --cyan: #00f0ff; /* interactivo / místico */
    --rosa: #ff2d95; /* CTA crítico: SOLO botón de tirada */
    --texto: #e8e8f0; /* texto base */
    --texto-fuerte: #ffffff;
    --font-head: "Plus Jakarta Sans", system-ui, sans-serif;
    --font-body: "Be Vietnam Pro", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", ui-monospace, monospace;
    --font-display: "Playfair Display", Georgia, serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    background: var(--bg);
    color: var(--texto);
    font-family: var(--font-body);
    margin: 0;
  }

  /* Accesibilidad: los componentes (typewriter, parallax, fade-in) heredan la
     desactivación de animaciones cuando el usuario lo prefiere (brief §nota). */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }
</style>
